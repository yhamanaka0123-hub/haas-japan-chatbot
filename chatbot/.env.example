# Copy this file to .env.local and fill in your values
# .env.local is gitignored by Vite — never commit the actual key

# Your Google Gemini API key (create one at aistudio.google.com)
VITE_GEMINI_API_KEY=AIza...

# Base URL for GitHub Pages (e.g. /haas-japan-chatbot/ for username.github.io/haas-japan-chatbot/)
# Leave as / for local development
VITE_BASE_URL=/
